# freebsd/env.conf.example
#
# TEMPLATE -- copy to freebsd/env.conf (which is .gitignore'd) and edit
# THAT copy:
#
#   cp freebsd/env.conf.example freebsd/env.conf
#
# Single source of truth for every network address, path, and hostname
# used across freebsd/mariadb/ and freebsd/webapp/. Every shell script in
# this tree sources freebsd/env.conf instead of hardcoding an IP/path
# directly -- edit the values in your copy to match YOUR host's jail
# registry before running anything, then every script picks up the change
# automatically. The copy stays untracked so your real topology never
# collides with upstream changes to this template (learned when the
# reference install's `git pull` collided with a template addition).
#
# The values shipped here are placeholders, deliberately drawn from IETF's
# documentation-reserved ranges (RFC 5737 for IPv4: 192.0.2.0/24
# "TEST-NET-1"; RFC 3849 for IPv6: 2001:db8::/32) and the reserved
# "example.com" domain (RFC 2606) -- NOT this project's real network, and
# not usable as-is. These ranges are guaranteed by IETF to never be
# assigned to any real, routable host, specifically so documentation and
# examples never have to expose or resemble anyone's actual infrastructure.
# They will not work on a real network; you MUST replace every value below
# with your own before running anything. This covers IP addresses AND
# netmasks/prefix lengths AND hostnames AND paths AND interface names:
# every one of them is a placeholder, not a constraint this setup imposes
# on you. Nothing downstream of this file assumes any particular range,
# prefix length, or naming scheme beyond what you set here.
#
# This file is sourced with `.` (POSIX sh), not executed -- keep it to
# plain KEY=value assignments, no command substitution that depends on
# being run from a specific working directory.

# --- mariadb jail -------------------------------------------------------
MARIADB_JAIL_NAME="mariadb"
MARIADB_JAIL_HOSTNAME="mariadb.example.com"
MARIADB_JAIL_PATH="/jails/mariadb"
MARIADB_JAIL_EPAIR="epair7"
MARIADB_JAIL_IP="192.0.2.100"
# IPv4 CIDR prefix length applied to MARIADB_JAIL_IP (i.e. the "/24" in
# "192.0.2.100/24") -- this is YOUR subnet's size, not a fixed value. Set it
# to whatever `ifconfig <epair>b <ip>/<N> up` should actually use on your
# network.
MARIADB_JAIL_NETMASK="24"
MARIADB_JAIL_IP6="2001:db8::100"
# IPv6 prefix length applied to MARIADB_JAIL_IP6, same idea as
# MARIADB_JAIL_NETMASK above but for the "/64" in "<ip6>/64".
MARIADB_JAIL_IP6_PREFIX="64"
MARIADB_PORT="3306"

# --- webapp jail ---------------------------------------------------------
WEBAPP_JAIL_NAME="webapp"
WEBAPP_JAIL_HOSTNAME="webapp.example.com"
WEBAPP_JAIL_PATH="/jails/webapp"
WEBAPP_JAIL_EPAIR="epair8"
WEBAPP_JAIL_IP="192.0.2.101"
WEBAPP_JAIL_NETMASK="24"
WEBAPP_JAIL_IP6="2001:db8::101"
WEBAPP_JAIL_IP6_PREFIX="64"

# --- integrated jail (only used by `install.sh --mode integrated`) -------
# The all-in-one topology: MariaDB, the web stack, the streaming engine,
# AND Icecast all inside this single jail. Ignore this block entirely if
# you use the distributed (mariadb + webapp + per-station Icecast jails)
# topology above -- the two blocks describe alternative layouts, not
# jails that coexist.
INTEGRATED_JAIL_NAME="azuracast"
INTEGRATED_JAIL_HOSTNAME="azuracast.example.com"
INTEGRATED_JAIL_PATH="/jails/azuracast"
INTEGRATED_JAIL_EPAIR="epair9"
INTEGRATED_JAIL_IP="192.0.2.102"
INTEGRATED_JAIL_NETMASK="24"
INTEGRATED_JAIL_IP6="2001:db8::102"
INTEGRATED_JAIL_IP6_PREFIX="64"

# --- shared host-level networking (same for every jail on this host) ----
VM_PUBLIC_BRIDGE="vm-public"
DEFAULT_ROUTE_V4="192.0.2.254"
DEFAULT_ROUTE_V6_GW="fe80::1"

# --- database defaults (name/user only -- NEVER put a real password here,
#     this file is meant to be safe to commit) ---------------------------
AZURACAST_DB_NAME_DEFAULT="azuracast"
AZURACAST_DB_USER_DEFAULT="azuracast"
