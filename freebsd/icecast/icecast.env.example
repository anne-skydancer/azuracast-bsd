# freebsd/icecast/icecast.env.example
#
# Per-jail values for applying the freebsd/icecast/ template to ONE
# station's Icecast jail. This directory is a reusable TEMPLATE, not a
# single fixed jail like freebsd/mariadb/ or freebsd/webapp/, so these
# values deliberately do NOT live in the shared freebsd/env.conf (that
# file is scoped to this host's fixed single-instance jails) -- copy this
# file to `icecast.env` next to it, fill in the real values for the
# specific Icecast jail you're configuring right now, then run:
#
#   sh freebsd/icecast/render-supervisord-conf.sh
#
# `icecast.env` (once filled in) is .gitignore'd -- it holds a real
# password. Only this .example file is committed.

# This station's Icecast jail IPv4 (or IPv6) address -- e.g. the existing
# `skydancer` jail's address on your host. Any station's Icecast jail can
# be plugged in here; `skydancer` is just this project's worked example.
ICECAST_JAIL_IP=

# TCP port for supervisord's [inet_http_server]. Matches
# Frontend\Icecast::DEFAULT_SUPERVISOR_PORT (9002) -- override here (and to
# a matching value in this station's frontend_config.supervisor_port) only
# if you're running more than one Icecast jail and want them on distinct
# ports for some other reason (e.g. a shared firewall path).
ICECAST_SUPERVISOR_PORT=9002

# HTTP Basic auth credentials RemoteSupervisorClientFactory sends on every
# XML-RPC call (see backend/src/Radio/RemoteSupervisorClientFactory.php).
# These must match this station's frontend_config.host /
# supervisor_username / supervisor_password fields exactly, as configured
# in the AzuraCast admin UI for this station.
ICECAST_SUPERVISOR_USERNAME=azuracast
ICECAST_SUPERVISOR_PASSWORD=CHANGE_ME_SET_VIA_ENV
