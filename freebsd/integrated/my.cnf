# freebsd/integrated/my.cnf
#
# MariaDB config fragment for the INTEGRATED (all-in-one-jail) topology --
# install to /usr/local/etc/mysql/conf.d/azuracast.cnf inside the
# integrated jail (freebsd/install.sh does this for you).
#
# Unlike freebsd/mariadb/my.cnf.tmpl (the distributed topology's config,
# which binds the mariadb jail's routable IPv4+IPv6 addresses so a
# separate webapp jail can reach it), everything that talks to MariaDB
# here lives in the SAME jail -- so this binds loopback only, both
# address families. Nothing outside the jail can reach the database at
# all, which is the whole point: same scoped-down posture as the webapp
# jail's Valkey config.
#
# Not a template: no @@TOKEN@@ substitution needed, loopback is loopback
# on every deployment.

[mysqld]
bind-address = 127.0.0.1,::1
port = 3306

# Match util/docker/mariadb's character-set defaults (and what
# backend/config/services.php expects).
character-set-server = utf8mb4
collation-server = utf8mb4_general_ci
